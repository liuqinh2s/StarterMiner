# ============================================================
#  StartupRadar 环境变量配置
#  标注 [必需] 的至少配一个，其余 [可选] 按需配置
# ============================================================

# ── AI API Key（三选一）[必需] ──
ZHIPU_API_KEY=your_zhipu_api_key
DEEPSEEK_API_KEY=your_deepseek_api_key
OPENAI_API_KEY=your_openai_api_key

# ── 创投数据平台 [可选] ──
ITJUZI_COOKIE=your_itjuzi_cookie
JINGDATA_TOKEN=your_jingdata_api_token

# ── 产品发现平台 [可选] ──
PH_TOKEN=your_product_hunt_developer_token

# ── 社交媒体 [可选] ──
ZHIHU_COOKIE=your_zhihu_cookie
TWITTER_BEARER_TOKEN=your_twitter_api_bearer_token
XUEQIU_COOKIE=your_xueqiu_cookie

# ── 海外创投数据库 [可选] ──
CRUNCHBASE_API_KEY=your_crunchbase_api_key

# ── 备用 [可选] ──
FIRECRAWL_API_KEY=your_firecrawl_api_key

# ── 招聘与联系方式 [可选] ──
GITHUB_TOKEN=your_github_personal_access_token
BOSS_COOKIE=your_boss_zhipin_cookie
LAGOU_COOKIE=your_lagou_cookie
TIANYANCHA_TOKEN=your_tianyancha_api_token
